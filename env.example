# ── ZombieWave V5 Environment Variables ──
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git!

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/zombiewave?retryWrites=true&w=majority

# JWT secret – any random long string, e.g. generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# Port (Railway sets this automatically, keep 3000 as fallback)
PORT=3000

# Node environment
NODE_ENV=production
